/* 金组件样式 */
.component-card {
    background: #fff;
    border-radius: 24rpx;
    padding: 24rpx 28rpx;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
    margin-top: 20rpx;
    border: 2rpx solid #fff0e0;
}

.card-title-row {
    display: flex;
    align-items: center;
    padding-bottom: 16rpx;
    border-bottom: 2rpx dashed #ffcc99;
}

.card-icon {
    width: 36rpx;
    height: 36rpx;
    border-radius: 50%;
    margin-right: 14rpx;
}

.gold-icon {
    background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
    box-shadow: 0 2rpx 6rpx rgba(255, 165, 0, 0.3);
}

.card-title {
    font-size: 30rpx;
    font-weight: 700;
    color: #333;
}

.input-grid {
    display: flex;
    flex-wrap: wrap;
    padding: 16rpx 0;
    gap: 12rpx;
}

.input-item {
    width: calc(50% - 6rpx);
    background: #fff8f0;
    border-radius: 14rpx;
    padding: 14rpx 16rpx;
    box-sizing: border-box;
    border: 2rpx solid transparent;
}

.input-item:focus-within {
    border-color: #FFB366;
    background: #fff4e6;
}

.input-label {
    display: block;
    font-size: 22rpx;
    color: #888;
    margin-bottom: 6rpx;
}

.input-field {
    font-size: 28rpx;
    color: #333;
    font-weight: 500;
    padding: 4rpx 0;
}

.result-box {
    background: #fff8f0;
    border-radius: 14rpx;
    padding: 16rpx 20rpx;
    margin-top: 8rpx;
}

.result-text {
    font-size: 22rpx;
    color: #666;
    line-height: 1.8;
    white-space: pre-wrap;
    word-break: break-all;
}
