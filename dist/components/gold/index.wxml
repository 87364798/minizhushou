<view class="component-card">
    <view class="card-title-row">
        <view class="card-icon gold-icon"></view>
        <text class="card-title">金</text>
    </view>
    <view class="input-grid">
        <view class="input-item" wx:for="{{items}}" wx:key="key">
            <text class="input-label">{{item.title}}</text>
            <input
                class="input-field"
                type="digit"
                placeholder="{{item.placeholder}}"
                value="{{item.value}}"
                data-idx="{{index}}"
                bindinput="bindKeyInput" />
        </view>
    </view>
    <view class="result-box">
        <text class="result-text">{{result}}</text>
    </view>
</view>
