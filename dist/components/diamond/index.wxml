<view class="component-card diamond-card">
    <view class="card-title-row" bindtap="bindCheckTitle">
        <view class="card-icon diamond-icon"></view>
        <text class="card-title">{{title}}</text>
        <text class="card-toggle">{{show ? '收起' : '展开'}}</text>
    </view>

    <view wx:if="{{show}}">
        <!-- 顶部控制区：尺寸单位 & 计价方式 -->
        <view class="control-row">
            <radio-group class="radio-group" bindchange="bindRadioLeft">
                <label class="radio-item">
                    <radio value="0" checked="{{isMm}}" color="#FF6B00" />
                    <text>mm</text>
                </label>
                <label class="radio-item">
                    <radio value="1" checked="{{!isMm}}" color="#FF6B00" />
                    <text>ct</text>
                </label>
            </radio-group>
            <radio-group class="radio-group" bindchange="bindRadioRight">
                <label class="radio-item">
                    <radio value="0" checked="{{isSinglePrice}}" color="#FF6B00" />
                    <text>单粒</text>
                </label>
                <label class="radio-item">
                    <radio value="1" checked="{{!isSinglePrice}}" color="#FF6B00" />
                    <text>总数</text>
                </label>
            </radio-group>
        </view>

        <!-- 镶工 / 添加行 -->
        <view class="picker-row">
            <picker bindchange="bindPickerChange" range="{{picker}}" range-key="name" value="{{pickerIndex}}">
                <view class="picker-box">
                    <text class="picker-text">{{picker[pickerIndex].name}}</text>
                </view>
            </picker>
            <input class="small-input" type="digit" placeholder="工费" value="{{picker[pickerIndex].wage}}" bindinput="bindWageInput" />
            <text class="num-label">项数</text>
            <input class="small-input" type="number" placeholder="1" value="{{addNum}}" bindinput="bindAddNumInput" />
            <view class="add-btn" data-tag="add" bindtap="bindAddAndDel">+添加</view>
        </view>

        <!-- 每项输入 -->
        <view class="diamond-list">
            <view class="diamond-row" wx:for="{{diamondDataList}}" wx:key="index">
                <view class="field-col">
                    <text class="field-label">{{isMm ? 'mm' : 'ct'}}</text>
                    <input class="field-input" type="digit" data-tag="size" data-idx="{{index}}" bindinput="bindDataListInput" value="{{item.size}}" />
                </view>
                <view class="field-col">
                    <text class="field-label">粒数</text>
                    <input class="field-input" type="number" data-tag="piece" data-idx="{{index}}" bindinput="bindDataListInput" value="{{item.piece}}" />
                </view>
                <view class="field-col">
                    <text class="field-label">{{isSinglePrice ? '单价' : '石价'}}</text>
                    <input class="field-input" type="digit" data-tag="price" data-idx="{{index}}" bindinput="bindDataListInput" value="{{item.price}}" />
                </view>
                <view class="del-btn" data-tag="del" data-idx="{{index}}" bindtap="bindAddAndDel">×</view>
            </view>
        </view>

        <view class="result-box">
            <text class="result-text">{{result}}</text>
        </view>
    </view>
</view>
