<wxc-panel border="{{false}}" class="myTitle flex">
    <checkbox-group bindchange="bindCheckTitle" data-checked="{{show}}" data-tag="diamond">
        <checkbox checked="{{show}}" class="scaleView">{{title}}</checkbox>
    </checkbox-group>
</wxc-panel>
<view class="myTitle-bg {{show?'':'hide'}} flex">
    <view class="line color--control"></view>
    <view class="row flex">
        <radio-group bindchange="bindRadioLeft">
            <label class="col col-6" wx:for="{{radioLeft}}" wx:key="radioLeft">
                <radio checked="{{item.checked}}" class="scaleView" value="{{index}}">{{item.name}}</radio>
            </label>
        </radio-group>
        <radio-group bindchange="bindRadioRight">
            <label class="col col-6" wx:for="{{radioRight}}" wx:for-item="right" wx:key="radioRight">
                <radio checked="{{right.checked}}" class="scaleView" disabled="{{disabled}}" value="{{index}}">{{right.name}}</radio>
            </label>
        </radio-group>
    </view>
    <view class="myRow font-12 c-secondary flex">
        <view class="col col-4">
            <picker bindchange="bindPickerChange" range="{{picker}}" rangeKey="name" value="{{index}}">
                <view>{{picker[pickerIndex].name}}</view>
            </picker>
        </view>
        <input bindinput="bindWegeInput" class="col col-4 iput" type="digit" value="{{picker[pickerIndex].wage}}"></input>
        <view class="col col-4">
      项数：
    </view>
        <input bindinput="bindAddNumInput" class="col col-4 iput" type="number" value="{{addNum}}"></input>
        <view class="col col-6">
            <view bindtap="bindDiamondAddAndDel" class="btn cc" data-tag="add">添加</view>
        </view>
    </view>
    <view class="myRow font-12 pt c-secondary flex" wx:for="{{diamondDataList}}" wx:for-item="list" wx:key="diamondDataList">
        <view class="col col-3">
        {{disabled?'mm':'ct'}}：
      </view>
        <input bindinput="bindDataListInput" class="col col-3 iput" data-tag="size" id="{{index}}" type="digit" value="{{list.size}}"></input>
        <view class="col col-3">
        粒数：
      </view>
        <input bindinput="bindDataListInput" class="col col-3 iput" data-tag="piece" id="{{index}}" type="number" value="{{list.piece}}"></input>
        <view class="col col-3">
        石价：
      </view>
        <input bindinput="bindDataListInput" class="col col-3 iput" data-tag="price" id="{{index}}" type="number" value="{{list.price}}"></input>
        <view class="cc col col-3">
            <van-icon bindtap="bindDiamondAddAndDel" color="#888" data-tag="del" id="{{index}}" name="delete" size="20px"></van-icon>
        </view>
    </view>
    <view class="line-gray "></view>
    <text class="c-secondary" style="font-size: 24rpx; ">{{result}}</text>
</view>
