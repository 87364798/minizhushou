<view class="component-card additional-card">
    <view class="card-title-row" bindtap="bindCheckTitle">
        <view class="card-icon additional-icon"></view>
        <text class="card-title">附加</text>
        <text class="card-toggle">{{show ? '收起' : '展开'}}</text>
    </view>
    <view wx:if="{{show}}">
        <view class="list-row" wx:for="{{items}}" wx:key="index">
            <view class="field-box">
                <text class="field-label">项名</text>
                <input class="field-input" placeholder="名称" data-tag="name" data-idx="{{index}}" bindinput="bindDataListInput" value="{{item.name}}" />
            </view>
            <view class="field-box">
                <text class="field-label">金额</text>
                <input class="field-input" type="digit" placeholder="元" data-tag="total" data-idx="{{index}}" bindinput="bindDataListInput" value="{{item.total}}" />
            </view>
            <view class="del-btn" data-tag="del" data-idx="{{index}}" bindtap="bindAddAndDel">×</view>
        </view>
        <view class="add-btn" data-tag="add" bindtap="bindAddAndDel">+ 添加一项</view>
        <view class="result-box">
            <text class="result-text">{{result}}</text>
        </view>
    </view>
</view>
