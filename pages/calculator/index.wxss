/* 报价计算页面样式 */
page {
    background: linear-gradient(180deg, #fff4e6 0%, #ffffff 40%);
    min-height: 100vh;
}

.container {
    padding: 24rpx 28rpx 60rpx;
}

/* 顶部信息卡 */
.header-card {
    background: linear-gradient(135deg, #FF8A3D 0%, #FF6B00 100%);
    border-radius: 24rpx;
    padding: 32rpx;
    box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.18);
    color: #fff;
    margin-bottom: 24rpx;
}

.header-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24rpx;
}

.header-title {
    font-size: 36rpx;
    font-weight: 700;
    letter-spacing: 2rpx;
}

.header-date {
    font-size: 22rpx;
    opacity: 0.9;
}

.price-row {
    display: flex;
    gap: 20rpx;
    margin-bottom: 24rpx;
}

.price-box {
    flex: 1;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 16rpx;
    padding: 20rpx 16rpx;
    text-align: center;
    backdrop-filter: blur(8rpx);
}

.price-label {
    display: block;
    font-size: 22rpx;
    opacity: 0.9;
    margin-bottom: 8rpx;
}

.price-value {
    font-size: 40rpx;
    font-weight: 700;
}

.price-unit {
    font-size: 20rpx;
    font-weight: 400;
    margin-left: 4rpx;
    opacity: 0.85;
}

.name-row {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.18);
    border-radius: 40rpx;
    padding: 16rpx 20rpx 16rpx 28rpx;
    margin-top: 4rpx;
}

.name-label {
    font-size: 26rpx;
    font-weight: 500;
    margin-right: 16rpx;
    white-space: nowrap;
    color: #fff;
    flex-shrink: 0;
    opacity: 0.95;
}

.name-input {
    flex: 1;
    font-size: 28rpx;
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 30rpx;
    padding: 14rpx 24rpx;
    min-height: 40rpx;
}

.name-input::placeholder {
    color: rgba(255, 255, 255, 0.6);
}

/* 汇总卡 */
.summary-card {
    background: #fff;
    border-radius: 24rpx;
    padding: 28rpx 32rpx;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
    margin-top: 24rpx;
    border: 2rpx solid #ffe6cc;
}

.summary-title-row {
    padding-bottom: 16rpx;
    border-bottom: 2rpx dashed #ffcc99;
}

.summary-title {
    font-size: 30rpx;
    font-weight: 700;
    color: #FF6B00;
}

.summary-detail {
    padding: 16rpx 0;
    min-height: 40rpx;
}

.summary-text {
    font-size: 24rpx;
    color: #666;
    line-height: 1.8;
    white-space: pre-wrap;
    word-break: break-all;
}

.summary-total-row {
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    padding-top: 16rpx;
    border-top: 2rpx dashed #ffcc99;
}

.total-label {
    font-size: 26rpx;
    color: #666;
    margin-right: 8rpx;
}

.total-value {
    font-size: 44rpx;
    font-weight: 700;
    color: #FF6B00;
    letter-spacing: 1rpx;
}

/* 底部勾选 + 复制 */
.footer-card {
    background: #fff;
    border-radius: 24rpx;
    padding: 24rpx 28rpx;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
    margin-top: 24rpx;
}

.checkbox-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8rpx;
    margin-bottom: 20rpx;
}

.checkbox-item {
    display: flex;
    align-items: center;
    padding: 8rpx 16rpx;
    border-radius: 12rpx;
}

.checkbox-text {
    font-size: 24rpx;
    color: #444;
    margin-left: 8rpx;
}

.copy-btn {
    background: linear-gradient(135deg, #FF8A3D 0%, #FF6B00 100%);
    color: #fff;
    text-align: center;
    padding: 20rpx 0;
    border-radius: 40rpx;
    font-size: 28rpx;
    font-weight: 600;
    box-shadow: 0 6rpx 16rpx rgba(255, 107, 0, 0.25);
}

.copy-btn:active {
    transform: scale(0.97);
    opacity: 0.9;
}
