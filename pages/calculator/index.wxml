<view class="container">
    <!-- 顶部金价信息卡 -->
    <view class="header-card">
        <view class="header-title-row">
            <text class="header-title">珠宝报价</text>
            <text class="header-date">{{date}}</text>
        </view>
        <view class="price-row">
            <view class="price-box">
                <text class="price-label">足金 Au9999</text>
                <text class="price-value">{{Au9999}}<text class="price-unit">元/克</text></text>
            </view>
            <view class="price-box">
                <text class="price-label">18K金 Au750</text>
                <text class="price-value">{{Au750}}<text class="price-unit">元/克</text></text>
            </view>
        </view>
        <view class="name-row">
            <text class="name-label">品名</text>
            <input class="name-input" placeholder="请输入品名" bindinput="bindInputName" value="{{name}}" />
        </view>
    </view>

    <!-- 金组件 -->
    <gold bind:goldSum="bindgoldSum"></gold>

    <!-- 钻石组件 -->
    <diamond bind:diamondSum="bindDiamondSum0" pickerIndex="0" title="主石"></diamond>
    <diamond bind:diamondSum="bindDiamondSum1" pickerIndex="1" title="副石"></diamond>

    <!-- 附加组件 -->
    <additional bind:addSum="bindaddSum"></additional>

    <!-- 汇总 -->
    <view class="summary-card">
        <view class="summary-title-row">
            <text class="summary-title">总价</text>
        </view>
        <view class="summary-detail">
            <text class="summary-text">{{sumMary.str}}</text>
        </view>
        <view class="summary-total-row">
            <text class="total-label">造价：</text>
            <text class="total-value">¥{{sumMary.sumMoney}}</text>
        </view>
    </view>

    <!-- 勾选复制 -->
    <view class="footer-card">
        <checkbox-group bindchange="bindCheckCopy">
            <view class="checkbox-row">
                <label class="checkbox-item" wx:for="{{footer}}" wx:key="name">
                    <checkbox value="{{index}}" checked="{{item.checked}}" disabled="{{item.disabled}}" color="#FF6B00" />
                    <text class="checkbox-text">{{item.name}}</text>
                </label>
            </view>
        </checkbox-group>
        <view class="copy-btn" bindtap="copyData">复制报价</view>
    </view>
</view>
