/* ============== 全局：锁定一屏 ============== */
.page-wrap {
    width: 100vw;
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, #fff4e6 0%, #fff9f0 40%, #fafafa 100%);
    box-sizing: border-box;
    overflow: hidden;
}

/* ============== 顶部标题 ============== */
.header-bar {
    display: flex;
    align-items: center;
    padding: 16rpx 24rpx;
    background: linear-gradient(135deg, #FF9900 0%, #ffb347 100%);
    box-shadow: 0 4rpx 12rpx rgba(255, 153, 0, 0.2);
    flex-shrink: 0;
}

.title-main {
    font-size: 32rpx;
    font-weight: 700;
    color: #fff;
    letter-spacing: 2rpx;
}

.title-dot {
    width: 6rpx;
    height: 6rpx;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.8);
    margin: 0 12rpx;
}

.title-sub {
    font-size: 22rpx;
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: 0.5rpx;
}

/* ============== 主体两列 ============== */
.main-grid {
    display: flex;
    flex-direction: row;
    flex: 1;
    padding: 16rpx;
    gap: 16rpx;
    box-sizing: border-box;
    min-height: 0;
}

.left-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12rpx;
    min-height: 0;
}

.right-col {
    flex: 1.1;
    display: flex;
    flex-direction: column;
    min-height: 0;
}

/* ============== 左侧：Canvas 卡片 ============== */
.canvas-box {
    flex: 1;
    background: #ffffff;
    border-radius: 20rpx;
    padding: 16rpx;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    min-height: 0;
}

.canvas-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #fafafa 0%, #f0f0f0 100%);
    border-radius: 12rpx;
    min-height: 0;
    overflow: hidden;
}

.mini-label {
    font-size: 22rpx;
    font-weight: 600;
    color: #333;
    padding-left: 12rpx;
    border-left: 4rpx solid #FF9900;
    margin-bottom: 12rpx;
    flex-shrink: 0;
}

.preview-canvas {
    display: block;
}

/* ============== 模式选择 ============== */
.mode-box {
    background: #ffffff;
    border-radius: 16rpx;
    padding: 12rpx 16rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
    flex-shrink: 0;
}

.mode-group {
    display: flex;
    flex-direction: row;
    gap: 12rpx;
}

.mode-item {
    flex: 1;
    padding: 12rpx 0;
    background: #f8f5ef;
    border-radius: 12rpx;
    text-align: center;
    font-size: 24rpx;
    color: #555;
}

.mode-item::after {
    border: none !important;
}

/* ============== 右列：参数网格 ============== */
.params-grid {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10rpx;
    min-height: 0;
    overflow: visible;
}

.param-cell {
    background: #ffffff;
    border-radius: 16rpx;
    padding: 10rpx 14rpx 8rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-sizing: border-box;
    min-height: 0;
    overflow: visible;
}

.param-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 4rpx;
    flex-shrink: 0;
}

.param-title {
    font-size: 22rpx;
    font-weight: 600;
    color: #333;
    padding-left: 10rpx;
    border-left: 4rpx solid #FF9900;
}

.param-input-box {
    display: flex;
    align-items: center;
    background: #fffbf5;
    border: 2rpx solid #f0e4cc;
    border-radius: 10rpx;
    padding: 4rpx 12rpx;
}

.param-input {
    width: 80rpx;
    height: 36rpx;
    text-align: center;
    font-size: 22rpx;
    color: #FF9900;
    font-weight: 600;
}

.param-unit {
    font-size: 18rpx;
    color: #999;
    margin-left: 6rpx;
}

/* ============== 只读字段（副副间距）样式 ============== */
.param-cell-readonly {
    background: linear-gradient(135deg, #fafafa 0%, #f4f4f4 100%);
    border: 2rpx dashed #dcdcdc;
}

.param-input-readonly {
    color: #FF9900;
    font-weight: 600;
    text-align: center;
    width: 80rpx;
    display: inline-block;
}

.result-line {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rpx 0 0;
    flex-shrink: 0;
}

.result-label {
    font-size: 16rpx;
    color: #a0a0a0;
    letter-spacing: 0.5rpx;
}

/* ============== 港度换算提示 ============== */
.hk-hint {
    padding: 4rpx 8rpx 6rpx;
    text-align: center;
    font-size: 16rpx;
    color: #FF9900;
    background: #fff5e6;
    border-radius: 8rpx;
    margin-top: 4rpx;
    flex-shrink: 0;
}

/* ============== 滑条与气泡 ============== */
.slider-wrap {
    position: relative;
    padding: 6rpx 16rpx 4rpx;
    flex-shrink: 0;
    overflow: visible;
}

.bubble {
    position: absolute;
    top: -4rpx;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #FF9900 0%, #FF6B00 100%);
    color: #fff;
    padding: 2rpx 12rpx;
    border-radius: 8rpx;
    font-size: 18rpx;
    font-weight: 600;
    white-space: nowrap;
    pointer-events: none;
    box-shadow: 0 2rpx 6rpx rgba(255, 153, 0, 0.3);
    z-index: 10;
}

.param-slider {
    margin: 24rpx 0 2rpx;
}

.range-line {
    display: flex;
    justify-content: space-between;
    font-size: 16rpx;
    color: #b8a582;
    padding: 0 4rpx;
    flex-shrink: 0;
}

