/* pages/transformation/index.wxss */

page {
    background: linear-gradient(180deg, #fff6e8 0%, #ffe8cc 30%, #ffd9b0 100%);
    min-height: 100vh;
}

.page-wrap {
    padding: 24rpx 20rpx 40rpx;
}

/* ===== 顶部标题卡片 ===== */
.header-card {
    background: linear-gradient(135deg, #FF9900 0%, #FF6B00 100%);
    border-radius: 20rpx;
    padding: 28rpx 32rpx;
    margin-bottom: 24rpx;
    box-shadow: 0 8rpx 20rpx rgba(255, 107, 0, 0.25);
    color: #fff;
}

.header-title {
    font-size: 36rpx;
    font-weight: 700;
    letter-spacing: 2rpx;
}

.header-sub {
    font-size: 22rpx;
    opacity: 0.92;
    margin-top: 8rpx;
}

/* ===== 每个制式的卡片 ===== */
.grid-item {
    background: #ffffff;
    border-radius: 16rpx;
    padding: 20rpx 24rpx 16rpx;
    margin-bottom: 18rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
    border: 2rpx solid rgba(255, 153, 0, 0.1);
}

.grid-title {
    font-size: 26rpx;
    color: #333;
    font-weight: 600;
    margin-bottom: 0;
}

/* ===== 标题行：圆形 logo + 文字 ===== */
.grid-title-row {
    display: flex;
    align-items: center;
    margin-bottom: 10rpx;
}

.logo-circle {
    margin-right: 16rpx;
    flex-shrink: 0;
    position: relative;
}

/* 国旗 PNG：保持原始形状与透明区域，不做任何裁剪、背景、边框 */
.logo-flag {
    background: transparent;
    border: none;
    box-shadow: none;
}

.logo-img {
    width: 60rpx;
    height: 60rpx;
    display: block;
}

/* 矢量图标容器（直径 / 周长）：保持圆形 */
.logo-vector {
    width: 56rpx;
    height: 56rpx;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, #fff 0%, #ffe9c7 100%);
    border: 2rpx solid #ffb366;
    box-shadow: 0 2rpx 6rpx rgba(255, 153, 0, 0.2);
}

/* 矢量图标内部：圆环 */
.vec-ring {
    position: absolute;
    left: 14rpx;
    top: 14rpx;
    width: 28rpx;
    height: 28rpx;
    border: 2rpx solid #FF6B00;
    border-radius: 50%;
}

/* 直径图：横向直径线 */
.vec-diameter-line {
    position: absolute;
    left: 10rpx;
    top: 50%;
    width: 36rpx;
    height: 0;
    border-top: 2rpx dashed #FF6B00;
    transform: translateY(-50%);
}

/* 周长图：用一个粗圆环表示周长 */
.vec-circ-arrow {
    position: absolute;
    left: 12rpx;
    top: 12rpx;
    width: 32rpx;
    height: 32rpx;
    border: 3rpx solid #FF6B00;
    border-radius: 50%;
    border-right-color: transparent;
    border-bottom-color: transparent;
}

/* 矢量图中心文字标签 */
.vec-label {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2rpx;
    text-align: center;
    font-size: 16rpx;
    color: #FF6B00;
    font-weight: 700;
    line-height: 1;
}

/* 输入框一行 */
.grid-input-row {
    display: flex;
    align-items: center;
    background: #fff7ec;
    border-radius: 12rpx;
    padding: 4rpx 16rpx;
    border: 2rpx solid #ffd9a8;
}

.grid-input {
    flex: 1;
    height: 60rpx;
    font-size: 28rpx;
    color: #FF6B00;
    font-weight: 600;
}

.grid-unit {
    font-size: 22rpx;
    color: #888;
    margin-left: 8rpx;
}

/* 滑条 */
.grid-slider {
    margin: 10rpx 0 4rpx;
}

/* 底部提示行 */
.grid-hint-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rpx;
}

.range-txt {
    font-size: 20rpx;
    color: #c49c6a;
}

.grid-hint {
    font-size: 20rpx;
    color: #aa7b4a;
    text-align: center;
    flex: 1;
    margin: 0 8rpx;
}

/* 底部提示 */
.footer-tip {
    text-align: center;
    margin-top: 28rpx;
    font-size: 22rpx;
    color: #a07a50;
    opacity: 0.8;
}
